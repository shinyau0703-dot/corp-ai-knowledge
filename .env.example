# 複製此檔案為 .env，填入實際值後啟動服務
# cp .env.example .env

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=eaih_app
POSTGRES_USER=eaih_app
POSTGRES_PASSWORD=請修改為強密碼

# JWT 簽署金鑰（至少 32 字元的隨機字串）
JWT_SECRET=請修改為隨機字串

# Ollama（本機 LLM 推論服務）
# 若 Ollama 跑在 Docker host：http://host.docker.internal:11434
# 若跑在同一個 Compose 網路中：http://ollama:11434
OLLAMA_HOST=http://host.docker.internal:11434
